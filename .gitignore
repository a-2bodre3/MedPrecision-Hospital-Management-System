# ==========================================
# 💻 IDEs & System Files (مهم جداً للـ Visual Studio)
# ==========================================
.vs/                    # ⚠️ كاش فيجوال ستوديو (أهم سطر لازم تضيفه)
.vscode/                # إعدادات VS Code الخاصة بك
.idea/                  # إعدادات WebStorm / Rider
*.suo                   # خيارات المستخدم للـ Solution
*.user                  # إعدادات المطور الشخصية للمشاريع
*.userosscache
*.sln.docstates
.DS_Store               # ملفات نظام الماك
Thumbs.db               # ملفات نظام الويندوز

# ==========================================
# 🌐 UI / Frontend (Angular)
# ==========================================
node_modules/           # مكتبات الفرونت
dist/                   # ملفات البلد النهائي
.angular/               # كاش الأنجولار
out-tsc/                # مخرجات الـ TypeScript
.sass-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# 🔌 API / Backend (.NET)
# ==========================================
bin/                    # ملفات الـ Build للباك إيند
obj/                    # ملفات الـ Build المؤقتة
# لو بتستخدم قاعدة بيانات local زي SQLite للتطوير:
*.db
*.db-shm
*.db-wal

# ==========================================
# 🔑 Secrets & Environments
# ==========================================
.env
.env*.local             # ملفات البيئة المحلية اللي فيها الباسوردات
appsettings.local.json  # لو عندك إعدادات داتابيز محلية مش عاوز ترفعها

# ==========================================
# 📝 Logs
# ==========================================
*.log